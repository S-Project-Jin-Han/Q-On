generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QR {
  id        Int      @id @default(autoincrement())
  hostId    Int
  code      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  host    profiles @relation(fields: [hostId], references: [id])
  classes classes[]

  @@unique([id, hostId])
}

model classes {
  id              Int       @id @default(autoincrement())
  qrId            Int
  startTime       DateTime?
  progressMinutes Int?
  preopenMinutes  Int?
  lateMinutes     Int?
  expiredMinutes  Int?
  createdAt       DateTime  @default(now())

  qr       QR        @relation(fields: [qrId], references: [id])
  checkIns checkIns[]
}

model checkIns {
  id        Int       @id @default(autoincrement())
  classDate DateTime
  userId    Int
  classId   Int
  startedAt DateTime?
  endedAt   DateTime?
  state     State?
  isChecked Boolean   @default(false)

  user    profiles @relation(fields: [userId], references: [id])
  classes classes  @relation(fields: [classId], references: [id])

  @@unique([id, classDate, userId, classId])
  @@map("check_ins")
}

model profiles {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @db.Uuid
  name        String?
  role        Role?
  createdAt   DateTime  @default(now())
  isOnboarding Boolean

  qrs      QR[]
  checkIns checkIns[]
}

enum State {
  ON_TIME
  LATE
  EARLY_LEAVE
  ABSENT
}

enum Role {
  ADMIN
  OWNER
  HOST
  MEMBER
}
